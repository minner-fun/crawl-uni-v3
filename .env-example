MAINNET_RPC_URL=""
# WebSocket 端点（用于实时事件订阅，与 HTTP RPC 不同格式）
# Alchemy: wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
MAINNET_WS_URL=""

# execution_engine：执行账户私钥（用于签名 mint / collect / burn 等写操作）
EXECUTOR_PRIVATE_KEY=""

# notification_engine：Telegram Bot 通知
# 1. 向 @BotFather 创建 Bot，获取 token
# 2. 向 Bot 发送任意消息，然后访问 https://api.telegram.org/bot{TOKEN}/getUpdates 获取 chat_id
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# PostgreSQL 连接（二选一）
# 方式一：完整 URL（优先）
DATABASE_URL=""
# 方式二：分字段（DATABASE_URL 为空时生效）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWD=12345678
DB_NAME=v3info
